version: "3.8"

services:
  platform:
    image: ghcr.io/sultonxon/testify_platform:{version}
    env_file: platform.env
    ports:
      - "5002:5002"
    networks:
      - testify-net
    deploy:
      replicas: 1
      restart_policy:
        condition: on-failure
        delay: 5s
        max_attempts: 3
      update_config:
        parallelism: 1
        delay: 10s
        order: start-first

networks:
  testify-net:
    external: true
