# NEXT_PUBLIC_* vars are baked into the image at build time (next.config.ts output: standalone).
# These are here for reference — the .env file in the source repo sets the build-time values.
# Only non-public server-side vars (without NEXT_PUBLIC_ prefix) can be overridden at runtime.

NEXT_PUBLIC_API_URL=https://platform.testifypro.uz
NEXT_PUBLIC_AUTH_AUTHORITY=https://taccount.testifypro.uz
NEXT_PUBLIC_AUTH_CLIENT_ID=testify-platform-client
NEXT_PUBLIC_TENANT_ID_HEADER=TenantId
